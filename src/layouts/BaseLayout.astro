---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Print on Demand業界の最新ニュースをお届けするメディア' } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="alternate" type="application/rss+xml" title="PrintonFocus RSS" href="/rss.xml" />
    <title>{title} | PrintonFocus</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="site-title">PrintonFocus</a>
        <span class="site-tagline">Print on Demand Daily News</span>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} PrintonFocus. All rights reserved.</p>
      <p><a href="/rss.xml">RSS</a></p>
    </footer>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial,
      'Noto Sans JP', sans-serif;
    line-height: 1.8;
    color: #333;
    background-color: #fafafa;
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  header {
    padding: 2rem 0 1rem;
    border-bottom: 2px solid #222;
    margin-bottom: 2rem;
  }

  .site-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #222;
    text-decoration: none;
  }

  .site-tagline {
    display: block;
    font-size: 0.85rem;
    color: #666;
    margin-top: 0.25rem;
  }

  main {
    min-height: 60vh;
  }

  footer {
    margin-top: 3rem;
    padding: 1.5rem 0;
    border-top: 1px solid #ddd;
    font-size: 0.85rem;
    color: #888;
    display: flex;
    justify-content: space-between;
  }

  footer a {
    color: #888;
  }

  a {
    color: #0066cc;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }
</style>
