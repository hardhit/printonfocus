---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('news')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="ホーム">
  <h1>最新ニュース</h1>
  <ul class="post-list">
    {
      posts.map((post) => (
        <li class="post-item">
          <a href={`/news/${post.id}/`} class="post-link">
            {post.data.image && (
              <img
                src={post.data.image}
                alt={post.data.photographer ? `Photo by ${post.data.photographer} on Unsplash` : post.data.title}
                class="post-thumb"
                loading="lazy"
              />
            )}
            <div class="post-body">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('ja-JP')}
              </time>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  h1 {
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    color: #222;
  }

  .post-list {
    list-style: none;
  }

  .post-item {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #eee;
  }

  .post-link {
    display: flex;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
  }

  .post-link:hover h2 {
    text-decoration: underline;
  }

  .post-thumb {
    width: 160px;
    height: 100px;
    object-fit: cover;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .post-body time {
    font-size: 0.8rem;
    color: #888;
  }

  .post-body h2 {
    font-size: 1.1rem;
    margin: 0.25rem 0 0.5rem;
    color: #222;
  }

  .post-body p {
    font-size: 0.95rem;
    color: #555;
  }
</style>
