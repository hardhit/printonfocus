---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article>
    {post.data.image && (
      <figure class="hero-image">
        <img
          src={post.data.image}
          alt={post.data.photographer ? `Photo by ${post.data.photographer} on Unsplash` : post.data.title}
        />
        {post.data.photographer && (
          <figcaption>
            Photo by <a href={post.data.photographerUrl} target="_blank" rel="noopener noreferrer">{post.data.photographer}</a> on Unsplash
          </figcaption>
        )}
      </figure>
    )}
    <header class="article-header">
      <time datetime={post.data.pubDate.toISOString()}>
        {post.data.pubDate.toLocaleDateString('ja-JP')}
      </time>
      <h1>{post.data.title}</h1>
      <p class="author">by {post.data.author}</p>
      {post.data.country && <span class="country-badge">{post.data.country}</span>}
      {
        post.data.tags.length > 0 && (
          <div class="tags">
            {post.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )
      }
    </header>
    <div class="content">
      <Content />
    </div>
    <footer class="article-footer">
      <a href="/">&larr; 記事一覧に戻る</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .hero-image {
    margin: 0 0 1.5rem;
  }

  .hero-image img {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 6px;
  }

  .hero-image figcaption {
    font-size: 0.75rem;
    color: #999;
    margin-top: 0.4rem;
    text-align: right;
  }

  .hero-image figcaption a {
    color: #999;
    text-decoration: underline;
  }

  .article-header {
    margin-bottom: 2rem;
  }

  .article-header time {
    font-size: 0.85rem;
    color: #888;
  }

  .article-header h1 {
    font-size: 1.5rem;
    margin: 0.5rem 0;
    line-height: 1.4;
  }

  .author {
    font-size: 0.85rem;
    color: #666;
  }

  .tags {
    margin-top: 0.5rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.75rem;
    background: #eee;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    color: #555;
  }

  .country-badge {
    display: inline-block;
    font-size: 0.75rem;
    background: #e0f0ff;
    color: #1a6bb5;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    font-weight: 600;
    margin-top: 0.4rem;
  }

  .content {
    font-size: 1rem;
    line-height: 1.9;
  }

  .content :global(h2) {
    font-size: 1.2rem;
    margin: 2rem 0 0.75rem;
  }

  .content :global(p) {
    margin-bottom: 1rem;
  }

  .content :global(ul),
  .content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .article-footer {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid #eee;
  }
</style>
