---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Resolve related posts
const allPosts = await getCollection('news');
const relatedPosts = post.data.relatedPosts
  .map((id: string) => allPosts.find((p) => p.id === id))
  .filter(Boolean);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article>
    {/* ① Hero image */}
    {post.data.image && (
      <figure class="hero-image">
        <img
          src={post.data.image}
          alt={post.data.photographer ? `Photo by ${post.data.photographer} on Unsplash` : post.data.title}
        />
        {post.data.photographer && (
          <figcaption>
            Photo by <a href={post.data.photographerUrl} target="_blank" rel="noopener noreferrer">{post.data.photographer}</a> on Unsplash
          </figcaption>
        )}
      </figure>
    )}

    {/* ② Country badge + tags */}
    <div class="meta-row">
      {post.data.country && <span class="country-badge">{post.data.country}</span>}
      {post.data.tags.length > 0 && (
        <div class="tags">
          {post.data.tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </div>

    {/* ③ Title */}
    <h1 class="article-title">{post.data.title}</h1>

    <div class="article-meta">
      <time datetime={post.data.pubDate.toISOString()}>
        {post.data.pubDate.toLocaleDateString('ja-JP')}
      </time>
      <span class="author">by {post.data.author}</span>
    </div>

    {/* ④ Source link */}
    {post.data.source && post.data.sourceUrl && (
      <p class="source-link">
        Source: <a href={post.data.sourceUrl} target="_blank" rel="noopener noreferrer">{post.data.source}</a>
      </p>
    )}

    {/* ⑤ Body */}
    <div class="content">
      <Content />
    </div>

    {/* ⑥ Related posts */}
    {relatedPosts.length > 0 && (
      <section class="related-posts">
        <h2>Related Articles</h2>
        <ul>
          {relatedPosts.map((rp: any) => (
            <li>
              <a href={`/news/${rp.id}/`}>{rp.data.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {/* ⑦ Opinion */}
    {post.data.opinion && (
      <aside class="opinion-box">
        <h2>Editor's Opinion</h2>
        <p>{post.data.opinion}</p>
      </aside>
    )}

    <footer class="article-footer">
      <a href="/">&larr; 記事一覧に戻る</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .hero-image {
    margin: 0 0 1.5rem;
  }

  .hero-image img {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 6px;
  }

  .hero-image figcaption {
    font-size: 0.75rem;
    color: #999;
    margin-top: 0.4rem;
    text-align: right;
  }

  .hero-image figcaption a {
    color: #999;
    text-decoration: underline;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .country-badge {
    font-size: 0.75rem;
    background: #e0f0ff;
    color: #1a6bb5;
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    font-weight: 600;
    white-space: nowrap;
  }

  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.7rem;
    background: #f0f0f0;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    color: #555;
  }

  .article-title {
    font-size: 1.5rem;
    margin: 0 0 0.5rem;
    line-height: 1.4;
  }

  .article-meta {
    font-size: 0.85rem;
    color: #888;
    margin-bottom: 0.5rem;
  }

  .article-meta .author {
    margin-left: 0.75rem;
    color: #666;
  }

  .source-link {
    font-size: 0.85rem;
    color: #888;
    margin-bottom: 2rem;
  }

  .source-link a {
    color: #1a6bb5;
    text-decoration: underline;
  }

  .content {
    font-size: 1rem;
    line-height: 1.9;
  }

  .content :global(h2) {
    font-size: 1.2rem;
    margin: 2rem 0 0.75rem;
  }

  .content :global(p) {
    margin-bottom: 1rem;
  }

  .content :global(ul),
  .content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .related-posts {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid #eee;
  }

  .related-posts h2 {
    font-size: 1rem;
    margin-bottom: 0.75rem;
    color: #333;
  }

  .related-posts ul {
    list-style: none;
    padding: 0;
  }

  .related-posts li {
    margin-bottom: 0.5rem;
  }

  .related-posts a {
    color: #1a6bb5;
    text-decoration: none;
    font-size: 0.95rem;
  }

  .related-posts a:hover {
    text-decoration: underline;
  }

  .opinion-box {
    margin-top: 2rem;
    padding: 1.25rem 1.5rem;
    background: #fafafa;
    border: 1px solid #e0e0e0;
    border-left: 4px solid #1a6bb5;
    border-radius: 4px;
  }

  .opinion-box h2 {
    font-size: 0.95rem;
    color: #1a6bb5;
    margin: 0 0 0.75rem;
    font-weight: 700;
  }

  .opinion-box p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: #444;
    margin: 0;
  }

  .article-footer {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid #eee;
  }
</style>
